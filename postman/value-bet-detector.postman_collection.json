            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"{{valueBetStatus}}\",\n  \"stakeAmount\": {{stakeAmount}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/value-bets/{{valueBetId}}/resolve",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "value-bets",
                "{{valueBetId}}",
                "resolve"
              ]
            }
          }
