    {
      "name": "Value Bets",
      "item": [
        {
          "name": "List Active Value Bets",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const first = Array.isArray(json) ? json[0] : Array.isArray(json.data) ? json.data[0] : Array.isArray(json.items) ? json.items[0] : Array.isArray(json.docs) ? json.docs[0] : null;",
                  "if (first && first.id) pm.environment.set('valueBetId', first.id);",
                  "if (first && first.classification) pm.environment.set('classification', first.classification);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/value-bets?page={{page}}&limit={{limit}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "value-bets"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}"
                },
                {
                  "key": "limit",
                  "value": "{{limit}}"
                }
              ]
            }
          }
        },
        {
