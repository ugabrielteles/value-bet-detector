    {
      "name": "Matches",
      "item": [
        {
          "name": "List Matches",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const first = Array.isArray(json) ? json[0] : Array.isArray(json.data) ? json.data[0] : Array.isArray(json.items) ? json.items[0] : Array.isArray(json.docs) ? json.docs[0] : null;",
                  "if (first && first.id) pm.environment.set('matchId', first.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/matches?status={{matchStatus}}&league={{league}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "matches"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "{{matchStatus}}"
                },
                {
                  "key": "league",
                  "value": "{{league}}"
                }
              ]
            }
          }
        },
