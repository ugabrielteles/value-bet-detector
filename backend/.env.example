PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/value-bet-detector
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
API_FOOTBALL_KEY=ea4a919e8b12b46183abf25aba19dd83
API_FOOTBALL_DEFAULT_LEAGUE_ID=39
API_FOOTBALL_INGESTION_WINDOW_DAYS=3
API_FOOTBALL_FUTURE_LOOKAHEAD_DAYS=14
# Restrict odds ingestion to a specific bookmaker name (case-insensitive contains).
# Default behavior in code is betano.
INGESTION_BOOKMAKER_FILTER=betano
# Comma-separated list of API-Football league IDs to ingest.
# If omitted, only the default league (API_FOOTBALL_DEFAULT_LEAGUE_ID) is used.
# Common IDs:
#   39  = Premier League (England)
#   140 = La Liga (Spain)
#   61  = Ligue 1 (France)
#   78  = Bundesliga (Germany)
#   135 = Serie A (Italy)
#   94  = Primeira Liga (Portugal)
#   88  = Eredivisie (Netherlands)
#   71  = Brasileirao Serie A
#   128 = Argentine Primera Division
#   253 = Major League Soccer (USA)
#   5   = UEFA Nations League
#   667 = International Friendlies
#   1   = World Cup
#   6   = Euro Championship
#   9   = Copa America
# Ignored when INGESTION_ALL_LEAGUES=true.
INGESTION_LEAGUE_IDS=39,253,5,667

# Set to true to fetch ALL worldwide fixtures for each date regardless of league/division.
# When enabled, INGESTION_LEAGUE_IDS is ignored and a single paginated call to
# /fixtures?date=<date> is made per day — covering every competition in the world.
# NOTE: Requires an API-Football plan with a high enough daily request quota.
INGESTION_ALL_LEAGUES=false
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
DEFAULT_KELLY_FRACTION=0.5

# Master key used to encrypt bookmaker credentials at rest.
# Use a strong random secret (or base64: + 32-byte key).
BOOKMAKER_CREDENTIALS_KEY=change-me-to-a-strong-secret

# Safety switch for real bet placement automation.
# Keep false in development and while validating selectors.
ALLOW_REAL_BETTING=false

# Reprocess window (minutes) for pending value bets in auto-bet polling.
# Helps enqueue bets when they were detected before the match turned live.
AUTO_BETS_POLL_LOOKBACK_MINUTES=120

# Grace period (minutes) before deactivating value bets whose match reference
# cannot be resolved (legacy/orphan records).
AUTO_BETS_ORPHAN_GRACE_MINUTES=30

# Grace period (minutes) to keep scheduled value bets before considering them stale
# if the match never transitions to live in local data.
AUTO_BETS_SCHEDULED_STALE_MINUTES=180

# Browser automation runtime behavior.
# Prefer false while validating bookmaker anti-bot / Cloudflare behavior locally.
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_LOCALE=pt-BR
PLAYWRIGHT_TIMEZONE=America/Sao_Paulo
# Optional: force a specific browser UA string.
PLAYWRIGHT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/133.0.0.0 Safari/537.36
# Optional residential proxy for environments blocked by bookmaker anti-bot / Cloudflare.
# Examples: http://host:port or socks5://host:port
PLAYWRIGHT_PROXY_SERVER=
PLAYWRIGHT_PROXY_USERNAME=
PLAYWRIGHT_PROXY_PASSWORD=
